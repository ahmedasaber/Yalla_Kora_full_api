{
    "info": {
      "name": "Yalla Kora API FULL",
      "_postman_id": "full-collection-yalla-kora",
      "description": "Full API Collection",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
      { "key": "base_url", "value": "http://localhost:3000/api" },
      { "key": "token", "value": "" },
      { "key": "field_id", "value": "" },
      { "key": "booking_id", "value": "" },
      { "key": "match_id", "value": "" }
    ],
    "auth": {
      "type": "bearer",
      "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
    },
    "item": [
      {
        "name": "🔐 Auth",
        "item": [
          {
            "name": "Register Player",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": {
                "mode": "raw",
                "raw": "{\n\"name\":\"Ahmed\",\n\"phone\":\"01012345678\",\n\"password\":\"123456\",\n\"role\":\"player\",\n\"age\":22\n}"
              },
              "url": "{{base_url}}/auth/register"
            }
          },
          {
            "name": "Register Owner",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": {
                "mode": "raw",
                "raw": "{\n\"name\":\"Ahmed\",\n\"phone\":\"01012345678\",\n\"password\":\"123456\",\n\"role\":\"owner\",\n\"field_name\":\"ملعب الهدف\"\n}"
              },
              "url": "{{base_url}}/auth/register"
            }
          },
          {
            "name": "Login",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const res = pm.response.json();",
                    "pm.collectionVariables.set('token', res.token);"
                  ]
                }
              }
            ],
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": {
                "mode": "raw",
                "raw": "{\n\"phone\":\"01012345678\",\n\"password\":\"123456\"\n}"
              },
              "url": "{{base_url}}/auth/login"
            }
          }
        ]
      },
  
      {
        "name": "👤 User",
        "item": [
          {
            "name": "Get Profile",
            "request": { "method": "GET", "url": "{{base_url}}/user/profile" }
          },
          {
            "name": "Update Profile",
            "request": {
              "method": "PUT",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{ \"name\": \"Ahmed Updated\" }" },
              "url": "{{base_url}}/user/profile"
            }
          }
        ]
      },
  
      {
        "name": "🏟️ Fields",
        "item": [
          { "name": "Get Fields", "request": { "method": "GET", "url": "{{base_url}}/fields" } },
          { "name": "Get Field By ID", "request": { "method": "GET", "url": "{{base_url}}/fields/{{field_id}}" } },
          {
            "name": "Create Field",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": {
                "mode": "raw",
                "raw": "{\n\"name\":\"ملعب الكابيتانو\",\n\"location\":\"القاهرة\",\n\"price_per_hour\":300,\n\"type\":\"5x5\",\n\"open_time\":\"09:00\",\n\"close_time\":\"23:00\"\n}"
              },
              "url": "{{base_url}}/fields"
            }
          },
          {
            "name": "Update Field",
            "request": {
              "method": "PUT",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{ \"price_per_hour\": 400 }" },
              "url": "{{base_url}}/fields/{{field_id}}"
            }
          }
        ]
      },
  
      {
        "name": "📅 Availability",
        "item": [
          {
            "name": "Get Schedule",
            "request": {
              "method": "GET",
              "url": "{{base_url}}/fields/{{field_id}}/schedule?date=2026-02-03"
            }
          },
          {
            "name": "Set Schedule",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": {
                "mode": "raw",
                "raw": "{\n\"date\":\"2026-02-03\",\n\"slots\":[{\"time\":\"17:00\",\"status\":\"available\"}]\n}"
              },
              "url": "{{base_url}}/fields/{{field_id}}/schedule"
            }
          }
        ]
      },
  
      {
        "name": "📖 Bookings",
        "item": [
          {
            "name": "Create Booking",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": {
                "mode": "raw",
                "raw": "{\n\"field_id\":\"{{field_id}}\",\n\"date\":\"2025-12-03\",\n\"time_from\":\"17:00\",\n\"time_to\":\"18:00\",\n\"players_count\":10,\n\"type\":\"5x5\",\n\"payment_method\":\"cash\"\n}"
              },
              "url": "{{base_url}}/bookings"
            }
          },
          { "name": "Get Upcoming", "request": { "method": "GET", "url": "{{base_url}}/bookings?type=upcoming" } },
          { "name": "Get Past", "request": { "method": "GET", "url": "{{base_url}}/bookings?type=past" } },
          { "name": "Booking Details", "request": { "method": "GET", "url": "{{base_url}}/bookings/{{booking_id}}" } },
          { "name": "Cancel Booking", "request": { "method": "DELETE", "url": "{{base_url}}/bookings/{{booking_id}}" } }
        ]
      },
  
      {
        "name": "💰 Wallet",
        "item": [
          { "name": "Get Balance", "request": { "method": "GET", "url": "{{base_url}}/wallet" } },
          {
            "name": "Charge Wallet",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{ \"amount\": 100, \"method\": \"vodafone_cash\" }" },
              "url": "{{base_url}}/wallet/charge"
            }
          }
        ]
      },
  
      {
        "name": "👥 Matches",
        "item": [
          { "name": "Get Matches", "request": { "method": "GET", "url": "{{base_url}}/matches" } },
          { "name": "Match Details", "request": { "method": "GET", "url": "{{base_url}}/matches/{{match_id}}" } },
          {
            "name": "Create Match",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": {
                "mode": "raw",
                "raw": "{\n\"field_id\":\"{{field_id}}\",\n\"date\":\"2025-12-03\",\n\"time\":\"21:00\",\n\"players_needed\":10,\n\"price_per_player\":30\n}"
              },
              "url": "{{base_url}}/matches"
            }
          },
          { "name": "Join Match", "request": { "method": "POST", "url": "{{base_url}}/matches/{{match_id}}/join" } },
          { "name": "Leave Match", "request": { "method": "POST", "url": "{{base_url}}/matches/{{match_id}}/leave" } }
        ]
      },
  
      {
        "name": "⭐ Ratings",
        "item": [
          {
            "name": "Rate Field",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{ \"rating\": 5, \"comment\": \"ملعب ممتاز\" }" },
              "url": "{{base_url}}/fields/{{field_id}}/rate"
            }
          }
        ]
      },
  
      {
        "name": "📊 Owner Dashboard",
        "item": [
          {
            "name": "Field Bookings",
            "request": {
              "method": "GET",
              "url": "{{base_url}}/owner/fields/{{field_id}}/bookings"
            }
          },
          {
            "name": "Daily Dashboard",
            "request": {
              "method": "GET",
              "url": "{{base_url}}/owner/fields/{{field_id}}/dashboard?date=2026-02-03"
            }
          }
        ]
      }
    ]
  }